# Spotify Web API — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Trakt API — create an app at https://trakt.tv/oauth/applications
TRAKT_API_KEY=your_trakt_client_id_here
TRAKT_USERNAME=your_trakt_username_here

# Bandcamp internal fan collection API — extract from a logged-in browser session
BANDCAMP_IDENTITY_COOKIE=your_identity_cookie_here
BANDCAMP_FAN_ID=your_fan_id_here

# Google Cloud — path to service account JSON with BigQuery write access
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# BigQuery (defaults match the project; override if needed)
BQ_PROJECT=personal-warehouse-495013
BQ_DATASET=raw_personal

# Netlify — dashboard build hook triggered after the daily dbt refresh
NETLIFY_BUILD_HOOK_URL=your_netlify_build_hook_url_here
